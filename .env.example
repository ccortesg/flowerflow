APP_NAME="FLOWER FLOW"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://app.flowerflow.com.mx

APP_LOCALE=es_MX
APP_FALLBACK_LOCALE=es_MX
APP_FAKER_LOCALE=es_MX
APP_TIMEZONE=UTC

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=flowerflow
DB_USERNAME=flowerflow_user
DB_PASSWORD=
DB_TIMEZONE=+00:00

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_TIMEOUT=10
MAIL_FROM_ADDRESS=notificaciones@flowerflow.com.mx
MAIL_FROM_NAME="FLOWER FLOW"
MAIL_REPLY_TO_ADDRESS=convocatoria@flowerflow.com.mx
MAIL_REPLY_TO_NAME="FLOWER FLOW"
PRIVACY_REPLY_TO_ADDRESS=privacidad@flowerflow.com.mx
FLOWERFLOW_MAIL_QUEUE_CONNECTION=database
FLOWERFLOW_MAIL_QUEUE=default
FLOWERFLOW_MAIL_TRIES=4
FLOWERFLOW_MAIL_JOB_TIMEOUT=30

# Product controls. Production submissions remain disabled until legal v1.1
# and the owner explicitly authorizes activation.
FLOWERFLOW_PUBLIC_ENABLED=true
FLOWERFLOW_REGISTRATION_ENABLED=false
FLOWERFLOW_SUBMISSIONS_ENABLED=false
FLOWERFLOW_RESULTS_ENABLED=false
FLOWERFLOW_PANEL_ENABLED=true
FLOWERFLOW_TIMEZONE=America/Hermosillo
FLOWERFLOW_SUBMISSIONS_CLOSE_AT="2026-08-15 23:59:59"
FLOWERFLOW_MAX_TEAM_MEMBERS=5
FLOWERFLOW_MAX_SUBMISSIONS_PER_USER=3
FLOWERFLOW_MAX_UPLOAD_KIB=10240
FLOWERFLOW_CANONICAL_URL=https://app.flowerflow.com.mx

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
